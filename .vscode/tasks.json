    {
      "type": "docker-run",
      "label": "docker-run: debug",
      "dependsOn": [
        // "Run docker-compose up",
        "docker-build"
      ],
      "dockerRun": {
        "image": "vobchat:latest",
        "containerName": "vobchat",
        "command": "sh -c 'redis-server --port 6379 --bind 127.0.0.1 --protected-mode no --save \"\" --stop-writes-on-bgsave-error no & exec python -m debugpy --listen 0.0.0.0:5678 --wait-for-client -m flask run --host 0.0.0.0 --port 8050'",
        "env": {
          "FLASK_APP": "vobchat.app:server",
          "FLASK_ENV": "development"
        },
        "volumes": [
          {
            "containerPath": "/app", "localPath": "${workspaceFolder}"
          },
          {
            "containerPath": "/app/src", "localPath": "${workspaceFolder}/src"
          },
        ]
      },
      "python": {
        "args": [
          "run",
          "--debug",
          "--no-debugger",
          "--host",
          "0.0.0.0",
          "--port",
          "8050"
        ],
        "module": "flask"
      }
    }
  ]
}
